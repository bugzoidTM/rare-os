#!/bin/ash
# RARE-OS Init Script
# O primeiro processo (PID 1) após o kernel carregar.

echo "🚀 [RARE-OS] Iniciando sistema mínimo..."

# 1. Montar sistemas de arquivos virtuais essenciais
# O Rust precisa do /proc para gerenciar threads e /dev para dispositivos
echo "[RARE-OS] Montando filesystems virtuais..."
/bin/busybox mount -t proc proc /proc
/bin/busybox mount -t sysfs sysfs /sys
/bin/busybox mount -t tmpfs tmpfs /tmp
/bin/busybox mount -t devtmpfs devtmpfs /dev
/bin/busybox mkdir -p /dev/pts
/bin/busybox mount -t devpts devpts /dev/pts

# 2. Configurar Loopback (rede local)
# Necessário mesmo em sistemas offline para localhost (127.0.0.1)
echo "[RARE-OS] Configurando rede local..."
/bin/busybox ifconfig lo 127.0.0.1 netmask 255.0.0.0 up

# 3. Configurar PATH
export PATH=/bin:/sbin:/usr/bin:/usr/sbin

# 4. Verificar se o Motor RARE existe
if [ ! -x /bin/rare-engine ]; then
    echo "[ERRO CRÍTICO] /bin/rare-engine não encontrado ou não executável!"
    echo "[ERRO CRÍTICO] Entrando em modo de resgate (shell)."
    /bin/busybox sh
    exit 1
fi

# 5. Executar o Motor de IA
echo "🧠 [RARE-OS] Iniciando RARE Engine (Qwen2.5-1.5B)..."
echo "==================================================="
# O 'exec' substitui o processo shell pelo engine, economizando memória
exec /bin/rare-engine
